\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces {Estimated means for the effect of Condition depending on Congruency. Green rectangles represent differences in means where the pd \textgreater {} 97.5\%, indicating a consistent effect direction (Makowski et al., 2019). A crossover effect can be seen where the difference between arousal ratings between images labelled as AI-generated and those labelled as photographs, is reversed for incongruent trials.}{}}}{9}{figure.caption.16}\protected@file@percent }
\newlabel{fig-estimated\_means\_arousal}{{3}{9}{{Estimated means for the effect of Condition depending on Congruency. Green rectangles represent differences in means where the pd \textgreater {} 97.5\%, indicating a consistent effect direction (Makowski et al., 2019). A crossover effect can be seen where the difference between arousal ratings between images labelled as AI-generated and those labelled as photographs, is reversed for incongruent trials.}{\label {fig-estimated\_means\_arousal}}}{figure.caption.16}{}}
