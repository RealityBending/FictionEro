df2$BAIT_Bias <- rowMeans(select(df2,BAIT_InnovativeAI, BAIT_UniqueHuman, BAIT_EmotionalHuman, BAIT_InterestingAI, BAIT_TrustHuman, BAIT_ImpersonalAI, BAIT_PreferenceHuman), na.rm=TRUE)
