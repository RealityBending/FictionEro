df2$BAIT_Dangerous <- 6 - df2$BAIT_Dangerous
df2$BAIT_Worry <- 6 - df2$BAIT_Worry
df2$BAIT_ImageDistinctionBad <- 6 - df2$BAIT_ImageDistinctionBad
df2$BAIT_TextDifferentiation <- 6 - df2$BAIT_TextDifferentiation
