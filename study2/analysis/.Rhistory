names_prefix = "mean_Arousal_",
values_from = mean_arousal) |>
mutate(diff_arousal = `mean_Arousal_AIGenerated` - mean_Arousal_Photograph)) |>
mutate(Feedback_AILessArousing = as.factor(Feedback_AILessArousing)) |>
as.data.frame()
df2 |>
group_by(Feedback_AILessArousing, Condition ) |>
summarise(mean_Arousal = mean(Arousal, na.rm = TRUE),
sd_Arousal = sd(Arousal, na.rm = TRUE),.groups = "drop") |>
gt() |>
fmt_number(decimals = 3, use_seps = FALSE)
m_type_a <- readRDS("models/ZOIB/ModelArousal_2_ZOIB_type.rds")
estimate_contrasts(m_type_a, contrast = "Type", by="Gender", backend = "emmeans")
